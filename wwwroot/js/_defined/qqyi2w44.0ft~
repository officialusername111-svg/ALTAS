$(function () {
    set_active_sidebar('.resident-nav');

    const CONFIG = {
        endpoints: {
            getHousehold: '/Resident/getHousehold',
            getHouseholdMembers: '/Resident/getHouseholdMembers',
            getResident: '/Resident/getResident',
            saveResident: '/Resident/saveResident',
            saveHousehold: '/Resident/saveHousehold',
            getDemographic: '/Resident/getDemographic',
            getDemographicKpi: '/Resident/getDemographicKpi',
            getHouseholdToilet: '/Resident/getHouseholdToilet'
        },
        selectors: {
            tblHouseHold: '#tblHouseHold',
            divHouseholdCards: '#divHouseholdCards',
            searchHouseholdInput: '#searchHouseholdInput',
            mdlHouseHold: '#mdlHouseHold',
            inpResidentHousehold: '#inpResidentHousehold',
            hidHouseholdId: '#_hidHouseholdId',

            tblResident: '#tblResident',
            searchResidentInput: '#searchResidentInput',
            divResidentInformation: '#divResidentInformation',
            mdlResident: '#mdlResident',
            inpResidentBirthdate: '#inpResidentBirthdate',
            inpResidentAge: '#inpResidentAge',

            btnClearResident: '#btnClearResident',
            btnSaveResident: '#btnSaveResident',

            btnAddNewHousehold: '#btnAddNewHousehold',
            mdlNewHousehold: '#mdlNewHousehold',
            btnSaveHousehold: '#btnSaveHousehold',
            divNewHousehold: '#divNewHousehold',

            // demographics
            mdlDemographics: '#mdlDemographics',
            tblDemographic: '#tblDemographic',
            demographicKpi: '.demographic-kpi',
            lblDemographicTitle: '#lblDemographicTitle',
            lblDemographicCount: '#lblDemographicCount'
        }
    };

    // Category metadata: label + icon + resident vs household list
    const DEMOGRAPHIC_META = {
        PWD: { label: 'Persons With Disability', icon: 'bi-universal-access', kind: 'resident' },
        IP: { label: 'Indigenous People', icon: 'bi-globe-asia-australia', kind: 'resident' },
        Senior: { label: 'Senior Citizens', icon: 'bi-person-walking', kind: 'resident' },
        Women: { label: 'Women (25–60)', icon: 'bi-gender-female', kind: 'resident' },
        Youth: { label: 'Youth Citizens (14–25)', icon: 'bi-person-arms-up', kind: 'resident' },
        Children: { label: 'Children (Below 14)', icon: 'bi-person-hearts', kind: 'resident' },
        ToiletWith: { label: 'Households With Toilet', icon: 'bi-house-check', kind: 'household', withToilet: true },
        ToiletWithout: { label: 'Households Without Toilet', icon: 'bi-house-x', kind: 'household', withToilet: false }
    };

    // Cache of the loaded household records — card buttons resolve by id.
    let _householdCache = [];

    fnLoadHousehold();
    fnLoadResident();
    attachEventHandlers();

    function attachEventHandlers() {
        $(document)
            .on('input', CONFIG.selectors.searchHouseholdInput, debounce(fnLoadHousehold, 250))
            .on('click', `${CONFIG.selectors.divHouseholdCards} .btn-select-household`, handleHouseholdSelect)
            .on('click', `${CONFIG.selectors.divHouseholdCards} .btn-edit-household`, handleEditHousehold)

            .on('input', CONFIG.selectors.searchResidentInput, debounce(fnLoadResident, 250))
            .on('click', `${CONFIG.selectors.tblResident} .btn-select`, handleResidentSelect)

            .on('click', CONFIG.selectors.btnSaveResident, handleSaveResident)
            .on('click', CONFIG.selectors.btnClearResident, handleClearResident)
            .on('change', CONFIG.selectors.inpResidentBirthdate, handleComputeBD)

            .on('click', CONFIG.selectors.btnAddNewHousehold, handleAddNewHousehold)
            .on('click', CONFIG.selectors.btnSaveHousehold, handleSaveNewHousehold)
            .on('hidden.bs.modal', CONFIG.selectors.mdlNewHousehold, handleCloseNewHousehold)

            // demographics
            .on('shown.bs.modal', CONFIG.selectors.mdlDemographics, handleOpenDemographics)
            .on('click', CONFIG.selectors.demographicKpi, handleDemographicKpiClick);
    }

    function fnLoadHousehold() {
        const search = $(CONFIG.selectors.searchHouseholdInput).val();

        // Fetch households and their members together, then group.
        Promise.all([
            doAjax(CONFIG.endpoints.getHousehold, 'GET', { searchKeyword: search }),
            doAjax(CONFIG.endpoints.getHouseholdMembers, 'GET', { searchKeyword: search })
        ]).then(([households, members]) => {
            _householdCache = households || [];

            const $container = $(CONFIG.selectors.divHouseholdCards);

            if (!households || households.length === 0) {
                $container.html(`<div class="text-center py-4">
                                    <i class="bi bi-house-x fs-24 text-muted"></i>
                                    <p class="text-muted fs-11 mt-1 mb-0">No households found.</p>
                                 </div>`);
                return;
            }

            // Group members by household id
            const membersByHh = {};
            (members || []).forEach(m => {
                (membersByHh[m.HouseholdId] = membersByHh[m.HouseholdId] || []).push(m);
            });

            const cards = households.map(h => {
                const hhMembers = membersByHh[h.HouseholdId] || [];
                const toiletBadge = h.HasToiletFacility
                    ? `<span class="badge bg-success-subtle text-success fs-10"><i class="bi bi-house-check me-1"></i>With Toilet</span>`
                    : `<span class="badge bg-danger-subtle text-danger fs-10"><i class="bi bi-house-x me-1"></i>No Toilet</span>`;

                const rows = hhMembers.length === 0
                    ? `<tr><td colspan="4" class="text-center text-muted fst-italic fs-11 py-2">No members recorded.</td></tr>`
                    : hhMembers.map(m => {
                        const isHead = m.IsFamilyHead;
                        const nameCell = isHead
                            ? `<span class="fw-semibold">${escapeHtml(m.Resident || '')}</span>
                               <span class="badge bg-success bg-opacity-10 text-success fs-10 ms-1"><i class="bi bi-star-fill me-1"></i>Head</span>`
                            : escapeHtml(m.Resident || '');
                        return `<tr>
                                    <td class="fs-11 text-truncate">${nameCell}</td>
                                    <td class="fs-11 text-muted text-truncate">${escapeHtml(m.RelationshipToFamilyHead || '')}</td>
                                    <td class="fs-11 text-muted">${parseMSDate4DTable(m.Birthdate)}</td>
                                    <td class="fs-11 text-muted">${escapeHtml(m.Sex || '')}</td>
                                </tr>`;
                    }).join('');

                return `<div class="household-card border rounded-3 mb-3" data-hhid="${h.HouseholdId}">

                            <div class="d-flex justify-content-between align-items-center px-3 py-2 bg-light rounded-top">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="bi bi-house-door-fill text-secondary"></i>
                                    <div>
                                        <div class="fw-bold fs-13">Household ${escapeHtml(h.HouseHoldNo || '')}</div>
                                        <div class="text-muted fs-10">
                                            <i class="bi bi-geo-alt me-1"></i>${escapeHtml(h.PurokName || '—')}
                                            <span class="ms-2"><i class="bi bi-people me-1"></i>${h.MemberCount || hhMembers.length} member(s)</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    ${toiletBadge}
                                    <button class="btn btn-main-outline btn-sm py-1 px-2 btn-edit-household"
                                            data-hhid="${h.HouseholdId}" title="Edit Household">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                    <button class="btn btn-main btn-sm py-1 px-2 btn-select-household"
                                            data-hhid="${h.HouseholdId}" title="Select Household">
                                        Select
                                    </button>
                                </div>
                            </div>

                            <div class="px-3 py-2">
                                <table class="table table-sm table-borderless mb-0" style="table-layout:fixed; width:100%;">
                                    <colgroup>
                                        <col style="width:40%;">
                                        <col style="width:25%;">
                                        <col style="width:20%;">
                                        <col style="width:15%;">
                                    </colgroup>
                                    <thead>
                                        <tr class="text-muted fs-10 border-bottom">
                                            <th class="fw-semibold">Name</th>
                                            <th class="fw-semibold">Relationship</th>
                                            <th class="fw-semibold">Birthdate</th>
                                            <th class="fw-semibold">Sex</th>
                                        </tr>
                                    </thead>
                                    <tbody>${rows}</tbody>
                                </table>
                            </div>

                        </div>`;
            }).join('');

            $container.html(cards);
        });
    }

    // Select a household for the resident form
    function handleHouseholdSelect() {
        const hhid = $(this).data('hhid');
        const data = _householdCache.find(h => h.HouseholdId == hhid);
        if (!data) return;
        $(CONFIG.selectors.hidHouseholdId).val(data.HouseholdId);
        $(CONFIG.selectors.inpResidentHousehold).val(`${data.HouseHoldNo || ''} — ${data.PurokName || ''}`);
        $(CONFIG.selectors.mdlHouseHold).modal('hide');
    }

    // Edit a household — pre-fill the new-household modal and show it
    function handleEditHousehold() {
        const hhid = $(this).data('hhid');
        const data = _householdCache.find(h => h.HouseholdId == hhid);
        if (!data) return;

        $(CONFIG.selectors.mdlHouseHold).modal('hide');

        // populate fields
        $('#_hidNewHouseholdId').val(data.HouseholdId);
        $('[name="HouseHoldNo"]').val(data.HouseHoldNo || '');
        $('#StreetId').val(data.StreetId || '');
        $('#PurokId').val(data.PurokId || '');
        $('[name="Remarks"]').val(data.Remarks || '');
        $('[name="HasToiletFacility"]').prop('checked', !!data.HasToiletFacility);

        // update modal title to reflect edit mode
        $(CONFIG.selectors.mdlNewHousehold).find('h3').text('Edit Household Information');

        $(CONFIG.selectors.mdlNewHousehold).modal('show');
    }

    function fnLoadResident() {
        const search = $(CONFIG.selectors.searchResidentInput).val();
        doAjax(CONFIG.endpoints.getResident, 'GET', { searchKeyword: search }).then(res => {
            resetDataTable(CONFIG.selectors.tblResident);

            $(CONFIG.selectors.tblResident).DataTable({
                retrieve: true, searching: false, lengthMenu: [15, 20, 50], order: [], dom: 'rtip', data: res,
                pagingType: 'full_numbers', language: returnPagination(),
                columns: [
                    { title: 'Resident', data: 'Resident', visible: true, className: 'dt-start', orderable: false },
                    { title: 'Household', data: 'Household', className: 'dt-start', orderable: false },
                    { title: 'Sex', data: 'Sex', className: 'dt-center', orderable: false },
                    { title: 'Birthdate', data: 'Birthdate', className: 'dt-center', orderable: false, render: d => parseMSDate4DTable(d) },
                    { title: 'Age', data: 'Age', className: 'dt-center', orderable: false },
                    { title: 'BirthPlace', data: 'BirthPlace', className: 'dt-start', orderable: false },
                    {
                        title: 'Action', data: null, className: 'dt-center', width: '80px', orderable: false,
                        render: () => `<button class="btn btn-main-outline btn-outline-secondary ms-1 btn-sm py-1 btn-select"> Select <span class="icon-load me-1"></span></button>`
                    }
                ]
            });
        });
    }

    function handleResidentSelect() {
        const data = getSelectedRowData(this, CONFIG.selectors.tblResident);
        setValues(CONFIG.selectors.divResidentInformation, data);
        $(CONFIG.selectors.mdlResident).modal('hide');
    }

    function handleClearResident() {
        clearContent(CONFIG.selectors.divResidentInformation);
    }

    function handleComputeBD() {
        const birthdate = $(CONFIG.selectors.inpResidentBirthdate).val();
        if (!birthdate) {
            $(CONFIG.selectors.inpResidentAge).val(0);
            return;
        }

        const today = new Date();
        const bdate = new Date(birthdate);

        let age = today.getFullYear() - bdate.getFullYear();
        const monthDiff = today.getMonth() - bdate.getMonth();
        if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < bdate.getDate())) {
            age--;
        }
        $(CONFIG.selectors.inpResidentAge).val(age);
    }

    function handleAddNewHousehold() {
        // reset to add mode
        clearContent(CONFIG.selectors.divNewHousehold);
        $('#_hidNewHouseholdId').val('');
        $('[name="HasToiletFacility"]').prop('checked', false);
        $(CONFIG.selectors.mdlNewHousehold).find('h3').text('Household Infomation');

        $(CONFIG.selectors.mdlHouseHold).modal('hide');
        $(CONFIG.selectors.mdlNewHousehold).modal('show');
    }

    function handleCloseNewHousehold() {
        $(CONFIG.selectors.mdlNewHousehold).modal('hide');
        $(CONFIG.selectors.mdlHouseHold).modal('show');
    }

    function handleSaveNewHousehold() {
        const data = getValues(CONFIG.selectors.divNewHousehold);
        doAjax(CONFIG.endpoints.saveHousehold, 'POST', data)
            .then(res => {
                if (res && res.rtn.success === true) {
                    showToast('Successfully saved household information.', 'success');
                    fnLoadHousehold();
                    clearContent(CONFIG.selectors.divNewHousehold);
                    handleCloseNewHousehold();
                } else {
                    showToast(res.rtn.remarks, 'danger');
                }
            })
            .catch(error => {
                console.error('Error saving household information:', error);
                showToast('Failed to saved household information', 'danger');
            });
    }

    function handleSaveResident() {
        const data = getValues(CONFIG.selectors.divResidentInformation);
        doAjax(CONFIG.endpoints.saveResident, 'POST', data)
            .then(res => {
                if (res && res.rtn.success === true) {
                    showToast('Successfully saved resident information.', 'success');
                    fnLoadHousehold();
                    fnLoadResident();
                    clearContent(CONFIG.selectors.divResidentInformation);
                } else {
                    showToast(res.rtn.remarks, 'danger');
                }
            })
            .catch(error => {
                console.error('Error saving resident information:', error);
                showToast('Failed to saved resident information', 'danger');
            });
    }

    // ── Demographics ────────────────────────────────────────

    function handleOpenDemographics() {
        doAjax(CONFIG.endpoints.getDemographicKpi, 'GET', {}).then(kpi => {
            $('#kpiPWD').text(kpi.PWDCount ?? 0);
            $('#kpiIP').text(kpi.IPCount ?? 0);
            $('#kpiSenior').text(kpi.SeniorCount ?? 0);
            $('#kpiWomen').text(kpi.WomenCount ?? 0);
            $('#kpiYouth').text(kpi.YouthCount ?? 0);
            $('#kpiChildren').text(kpi.ChildrenCount ?? 0);
            $('#kpiToiletWith').text(kpi.HouseholdWithToilet ?? 0);
            $('#kpiToiletWithout').text(kpi.HouseholdWithoutToilet ?? 0);
        });

        // default to PWD on open
        $(CONFIG.selectors.demographicKpi).removeClass('border-primary border-2');
        $(`${CONFIG.selectors.demographicKpi}[data-cat="PWD"]`).addClass('border-primary border-2');
        fnLoadDemographicList('PWD');
    }

    function handleDemographicKpiClick() {
        const cat = $(this).data('cat');
        if (!cat) return;
        $(CONFIG.selectors.demographicKpi).removeClass('border-primary border-2');
        $(this).addClass('border-primary border-2');
        fnLoadDemographicList(cat);
    }

    function fnLoadDemographicList(category) {
        const meta = DEMOGRAPHIC_META[category];
        if (!meta) return;

        $(CONFIG.selectors.lblDemographicTitle)
            .html(`<i class="bi ${meta.icon} me-1"></i> ${meta.label}`);

        if (meta.kind === 'household') {
            doAjax(CONFIG.endpoints.getHouseholdToilet, 'GET', { withToilet: meta.withToilet }).then(res => {
                $(CONFIG.selectors.lblDemographicCount).text(res.length);
                resetDataTable(CONFIG.selectors.tblDemographic);
                $(CONFIG.selectors.tblDemographic).DataTable({
                    retrieve: true, searching: false, lengthMenu: [10, 20, 50], order: [],
                    dom: 'rtip', data: res, pagingType: 'full_numbers', language: returnPagination(),
                    columns: [
                        { title: 'Household No', data: 'HouseHoldNo', className: 'dt-center fw-semibold', orderable: false },
                        { title: 'Street', data: 'StreetName', className: 'dt-start', orderable: false },
                        { title: 'Purok', data: 'PurokName', className: 'dt-start', orderable: false },
                        { title: 'Members', data: 'MemberCount', className: 'dt-center', orderable: false },
                        {
                            title: 'Toilet', data: 'HasToiletFacility', className: 'dt-center', orderable: false,
                            render: d => d
                                ? createBadge('bg-success', '', 'With Toilet')
                                : createBadge('bg-danger', '', 'No Toilet')
                        }
                    ]
                });
            });
            return;
        }

        doAjax(CONFIG.endpoints.getDemographic, 'GET', { category }).then(res => {
            $(CONFIG.selectors.lblDemographicCount).text(res.length);
            resetDataTable(CONFIG.selectors.tblDemographic);
            $(CONFIG.selectors.tblDemographic).DataTable({
                retrieve: true, searching: false, lengthMenu: [10, 20, 50], order: [],
                dom: 'rtip', data: res, pagingType: 'full_numbers', language: returnPagination(),
                columns: [
                    { title: 'Resident', data: 'Resident', className: 'dt-start fw-semibold', orderable: false },
                    { title: 'Sex', data: 'Sex', className: 'dt-center', orderable: false },
                    { title: 'Age', data: 'Age', className: 'dt-center', orderable: false },
                    { title: 'Birthdate', data: 'Birthdate', className: 'dt-center', orderable: false, render: d => parseMSDate4DTable(d) },
                    { title: 'BirthPlace', data: 'BirthPlace', className: 'dt-start', orderable: false }
                ]
            });
        });
    }
});