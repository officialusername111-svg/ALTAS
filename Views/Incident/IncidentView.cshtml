@{
    ViewBag.Title = "Incident Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="mb-5">

    <div class="mb-4 mx-5">
        <div class="row mx-3 border-bottom-dash border-1 py-2">
            <div class="col-auto pe-0">
                <img src="/img/png/incident.png" alt="ATLAS Logo" class="icon-png">
            </div>
            <div class="col ps-0 d-flex align-items-center">
                <div>
                    <h3 class="fw-bold mb-0">Incident Management</h3>
                    <p class="text-muted fs-12 mb-0">
                        A centralized module for recording, managing, and monitoring barangay incident and complaint cases,
                        including parties involved and settlement schedules.
                    </p>
                </div>
            </div>
            <div class="col-auto d-flex align-content-end flex-wrap">
                <button type="button" class="btn btn-main-outline btn-sm fw-semibold" id="btnNewIncident">
                    <i class="bi bi-plus-lg me-1"></i>Create New Incident Report
                </button>
            </div>
        </div>
    </div>

    @* ── KPI + Dashboard Panel ──────────────────────────────────────────── *@
    <div id="divSummaryCards" class="px-4 mb-4">

        @* Period Filter Bar *@
        <div class="d-flex align-items-center gap-3 flex-wrap mb-3">

            @* Pills *@
            <ul class="nav dashboard-period-pills mb-0" id="periodTabs" role="tablist">
                <li class="nav-item">
                    <button class="nav-link fw-semibold fs-11 py-1 px-3"
                            data-period="Weekly" id="pill-weekly">
                        Weekly
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link active fw-semibold fs-11 py-1 px-3"
                            data-period="Monthly" id="pill-monthly">
                        Monthly
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link fw-semibold fs-11 py-1 px-3"
                            data-period="Yearly" id="pill-yearly">
                        Yearly
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link fw-semibold fs-11 py-1 px-3"
                            data-period="DateRange" id="pill-daterange">
                        Date Range
                    </button>
                </li>
            </ul>

            <span class="text-muted fs-10 fst-italic" id="lblPeriodRange"></span>

            @* Controls group — pushed to the right end *@
            <div class="d-flex align-items-center gap-2 ms-auto">

                @* Monthly controls — hidden by default, shown by JS *@
                <div id="ctrlMonthly" class="align-items-center gap-2" style="display:none;">
                    <select class="form-select form-select-sm fs-11 d-inline-block" id="selMonth" style="width:130px;">
                        <option value="1">January</option>
                        <option value="2">February</option>
                        <option value="3">March</option>
                        <option value="4">April</option>
                        <option value="5">May</option>
                        <option value="6">June</option>
                        <option value="7">July</option>
                        <option value="8">August</option>
                        <option value="9">September</option>
                        <option value="10">October</option>
                        <option value="11">November</option>
                        <option value="12">December</option>
                    </select>
                    <input type="number" class="form-control form-control-sm fs-11 d-inline-block ms-1" id="inpMonthYear"
                           style="width:88px;" placeholder="Year" min="2000" max="2099">
                </div>

                @* Yearly controls — hidden by default *@
                <div id="ctrlYearly" class="align-items-center gap-2" style="display:none;">
                    <input type="number" class="form-control form-control-sm fs-11 d-inline-block" id="inpYear"
                           style="width:88px;" placeholder="Year" min="2000" max="2099">
                </div>

                @* Date Range controls — hidden by default *@
                <div id="ctrlDateRange" class="align-items-center gap-2" style="display:none;">
                    <input type="date" class="form-control form-control-sm fs-11 d-inline-block" id="inpDateFrom" style="width:145px;">
                    <span class="text-muted fs-11 mx-1">to</span>
                    <input type="date" class="form-control form-control-sm fs-11 d-inline-block" id="inpDateTo" style="width:145px;">
                </div>

                @* Single Apply button — hidden for Weekly (auto), shown for all others *@
                <button type="button" class="btn btn-main btn-sm fs-11 py-1 px-3" id="btnApplyPeriod" style="display:none;">
                    <i class="bi bi-funnel me-1"></i> Apply
                </button>

            </div>
        </div>

        @* ── 3-column layout ─────────────────────────────────────────────── *@
        <div class="row g-3">

            @* ── COL 1 (LEFT): Upcoming Settlement Schedule ──────────────── *@
            <div class="col-md-3">
                <div class="card chart-border border-0 h-100">
                    <div class="card-body px-3 py-3 d-flex flex-column">

                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <h5 class="fw-bold mb-0">Upcoming Hearings</h5>
                            <span class="badge bg-primary-subtle text-primary fs-10 fw-semibold"
                                  id="lblUpcomingCount">—</span>
                        </div>
                        <p class="text-muted fs-12 mb-2 border-bottom-dash pb-2">
                            Next scheduled settlement hearings.
                        </p>

                        @* Schedule list — grows to fill, scrolls if long *@
                        <div id="divUpcomingSchedule" class="d-flex flex-column flex-grow-1"
                             style="overflow-y:auto;max-height:480px;">
                            <div class="text-center py-4">
                                <i class="bi bi-calendar-x fs-24 text-muted"></i>
                                <p class="text-muted fs-11 mt-1 mb-0 fst-italic">No upcoming hearings.</p>
                            </div>
                        </div>

                        <div class="pt-2 border-top mt-2">
                            <button type="button" class="btn btn-main-outline btn-sm w-100 fs-11 fw-semibold"
                                    id="btnViewAllSchedules">
                                <i class="bi bi-calendar-week me-1"></i> View All Schedules
                            </button>
                        </div>

                    </div>
                </div>
            </div>

            @* ── COL 2 (CENTER): KPI Numbers + Case Status ───────────────── *@
            <div class="col-md-5 d-flex flex-column">

                @* Headline KPIs — 4 across *@
                <div class="row g-3 mb-3">
                    <div class="col-3">
                        <div class="kpi-card text-start h-100">
                            <div class="text-muted fw-semibold fs-11">Total Incidents</div>
                            <div class="text-dark kpi-number pt-2" id="statTotal">—</div>
                            <span class="fs-10 text-muted" id="statTotalSub"></span>
                        </div>
                    </div>
                    <div class="col-3">
                        <div class="kpi-card text-start h-100">
                            <div class="text-muted fw-semibold fs-11">Settlement Rate</div>
                            <div class="text-dark kpi-number pt-2" id="statSettlementRate">—</div>
                            <span class="fs-10 text-muted">settled</span>
                        </div>
                    </div>
                    <div class="col-3">
                        <div class="kpi-card text-start h-100">
                            <div class="text-muted fw-semibold fs-11">Avg. Days</div>
                            <div class="text-dark kpi-number pt-2" id="statAvgDays">—</div>
                            <span class="fs-10 text-muted">to settle</span>
                        </div>
                    </div>
                    <div class="col-3">
                        <div class="kpi-card text-start h-100">
                            <div class="text-muted fw-semibold fs-11">Fees Collected</div>
                            <div class="text-dark kpi-number pt-2 fs-20" id="statTotalAmount">—</div>
                            <span class="fs-10 text-muted">Avg <span class="fw-bold text-primary" id="statAvgAmount">—</span></span>
                        </div>
                    </div>
                </div>

                @* Single Case Status card — stacked bar + status list (replaces 5 cards) *@
                <div class="kpi-card text-start mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div class="text-muted fw-semibold">Case Status Breakdown</div>
                        <span class="fs-10 text-muted">by resolution</span>
                    </div>

                    @* Stacked proportion bar *@
                    <div id="divResolutionBar" class="inc-resolution-bar mb-3"></div>

                    @* Status rows — count + percent per status *@
                    <div class="row g-2" id="divStatusList">
                        <div class="col-6">
                            <div class="d-flex align-items-center justify-content-between border rounded-2 px-2 py-1">
                                <span class="d-flex align-items-center gap-2">
                                    <span class="inc-status-dot" style="background:#0dcaf0;"></span>
                                    <span class="fs-11 text-muted">Open</span>
                                </span>
                                <span class="text-end">
                                    <span class="fw-bold fs-13 text-dark" id="statOpen">—</span>
                                    <span class="fs-10 text-info fw-semibold" id="statOpenPct">0%</span>
                                </span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="d-flex align-items-center justify-content-between border rounded-2 px-2 py-1">
                                <span class="d-flex align-items-center gap-2">
                                    <span class="inc-status-dot" style="background:#ffc107;"></span>
                                    <span class="fs-11 text-muted">On-going</span>
                                </span>
                                <span class="text-end">
                                    <span class="fw-bold fs-13 text-dark" id="statOngoing">—</span>
                                    <span class="fs-10 text-warning fw-semibold" id="statOngoingPct">0%</span>
                                </span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="d-flex align-items-center justify-content-between border rounded-2 px-2 py-1">
                                <span class="d-flex align-items-center gap-2">
                                    <span class="inc-status-dot" style="background:#198754;"></span>
                                    <span class="fs-11 text-muted">Settled</span>
                                </span>
                                <span class="text-end">
                                    <span class="fw-bold fs-13 text-dark" id="statSettled">—</span>
                                    <span class="fs-10 text-success fw-semibold" id="statSettledPct">0%</span>
                                </span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="d-flex align-items-center justify-content-between border rounded-2 px-2 py-1">
                                <span class="d-flex align-items-center gap-2">
                                    <span class="inc-status-dot" style="background:#6c757d;"></span>
                                    <span class="fs-11 text-muted">Dismissed</span>
                                </span>
                                <span class="text-end">
                                    <span class="fw-bold fs-13 text-dark" id="statDismissed">—</span>
                                    <span class="fs-10 text-secondary fw-semibold" id="statDismissedPct">0%</span>
                                </span>
                            </div>
                        </div>
                    </div>
                </div>

                @* Case trend chart — grows to fill, aligns bottom with side columns *@
                <div class="card chart-border border-0 flex-grow-1">
                    <div class="card-body px-3 py-3 d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <h5 class="fw-bold mb-0">Case Trend</h5>
                            <span class="text-muted fs-10 fst-italic" id="lblTrendSubtitle"></span>
                        </div>
                        <p class="text-muted fs-12 mb-3 border-bottom-dash pb-2">
                            Incidents filed within the selected period.
                        </p>
                        <div class="flex-grow-1" style="position:relative;min-height:160px;">
                            <canvas id="chartTrend"></canvas>
                        </div>
                    </div>
                </div>

            </div>

            @* ── COL 3 (RIGHT): Case Type + Top Residents ─────────────────── *@
            <div class="col-md-4 d-flex flex-column">

                @* By Case Type donut *@
                <div class="card chart-border border-0 mb-3">
                    <div class="card-body px-3 py-3">
                        <h5 class="fw-bold mb-1">By Case Type</h5>
                        <p class="text-muted fs-12 mb-3 border-bottom-dash pb-2">
                            Distribution of incidents by type.
                        </p>
                        <div class="d-flex align-items-center gap-3">
                            <div style="position:relative;width:110px;flex-shrink:0;">
                                <canvas id="chartCaseType"></canvas>
                                <div id="chartCaseTypeCenter"
                                     style="position:absolute;top:50%;left:50%;
                                            transform:translate(-50%,-50%);
                                            text-align:center;pointer-events:none;"></div>
                            </div>
                            <div id="divCaseTypeLegend" class="d-flex flex-column gap-1 fs-11 flex-grow-1" style="min-width:0;"></div>
                        </div>
                    </div>
                </div>

                @* Top residents — grows to fill remaining height, aligns bottom *@
                <div class="card chart-border border-0 flex-grow-1">
                    <div class="card-body px-3 py-3 d-flex flex-column h-100">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <h5 class="fw-bold mb-0">Top Cases</h5>
                            <select class="form-select form-select-sm fs-11"
                                    id="selTopResidentPartyType" style="width:120px;">
                                <option value="">All</option>
                                <option value="Complainant">Complainant</option>
                                <option value="Respondent">Respondent</option>
                            </select>
                        </div>
                        <p class="text-muted fs-12 mb-3 border-bottom-dash pb-2">
                            Residents with most cases this period.
                        </p>
                        <div id="divTopResidentCards" class="d-flex flex-column gap-2 flex-grow-1"
                             style="overflow-y:auto;">
                            <div class="text-center py-3">
                                <p class="text-muted fs-11 fst-italic mb-0">Loading...</p>
                            </div>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mt-2 pt-2 border-top">
                            <button class="btn btn-main-outline btn-sm py-1 px-2 fs-11"
                                    id="btnResidentPrev" disabled>
                                <i class="bi bi-chevron-left"></i>
                            </button>
                            <span class="text-muted fs-10" id="lblResidentPage">—</span>
                            <button class="btn btn-main-outline btn-sm py-1 px-2 fs-11"
                                    id="btnResidentNext">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                        </div>
                    </div>
                </div>

            </div>

        </div>

    </div>

    @* ── Incident List Panel ──────────────────────────────────────────────── *@
    <div id="divIncidentList" class="px-4">
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-body p-0">
                <div class="d-flex justify-content-between align-items-center px-3 pt-3 pb-2 border-bottom">
                    <span class="fw-semibold fs-13" style="color:#1a3a5c;">Incident Records</span>
                    <div class="search-box" style="width:280px;">
                        <i class="bi bi-search"></i>
                        <input type="text" class="form-control fs-11 border-elm"
                               id="searchIncidentList" placeholder="Search case no., name, status...">
                    </div>
                </div>
                <div class="px-2 pb-2">
                    <table id="tblIncidentList" class="display dataTable table-striped table-hover w-100"></table>
                </div>
            </div>
        </div>
    </div>

    @* ── Form Panel — hidden by default ─────────────────────────────────── *@
    <div id="divIncidentForm" class="px-4" style="display:none;">

        <div class="d-flex justify-content-end gap-1 mb-2">
            <button type="button" class="btn btn-main-outline btn-sm fw-semibold" id="btnPrintIncident">
                <i class="bi bi-printer me-1"></i> Print
            </button>
            <button type="button" class="btn btn-main-outline btn-sm fw-semibold" id="btnBackToList">
                <i class="bi bi-arrow-left me-1"></i> Back to Incident List
            </button>
        </div>

        <div class="row g-4">

            @* LEFT: Case Info + Parties *@
            <div class="col-7">
                <div id="divIncidentInformation">

                    <input type="hidden" name="IncidentID" id="_hidIncidentID" />
                    <input type="hidden" name="ResidentId_Complainant" id="_hidResidentId_Complainant" />
                    <input type="hidden" name="ResidentId_Respondent" id="_hidResidentId_Respondent" />

                    <h6 class="fs-16 fw-bold mt-5">Case Information</h6>

                    <div class="row">
                        <div class="col-4">
                            <div class="form-group mb-3">
                                <label class="fs-10 text-muted fw-semibold mb-1">KP Case No.</label>
                                <input type="text" class="form-control fs-11"
                                       name="KPCaseNo" id="inpKPCaseNo">
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="form-group mb-3">
                                <label class="fs-10 text-muted fw-semibold mb-1">Incident Date</label>
                                <input type="date" class="form-control fs-11"
                                       name="IncidentDate" id="inpIncidentDate">
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-6">
                            <div class="form-group mb-3">
                                <label class="fs-10 text-muted fw-semibold mb-1">Case Type</label>
                                <select class="form-select fs-11" name="CaseTypeID" id="inpCaseTypeID">
                                    <option value="" selected disabled>Select Case Type</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="form-group mb-3">
                                <label class="fs-10 text-muted fw-semibold mb-1">Complaint Type</label>
                                <select class="form-select fs-11" name="ComplaintTypeID" id="inpComplaintTypeID" disabled>
                                    <option value="" selected disabled>Select Case Type first</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12">
                            <div class="form-group mb-3">
                                <label class="fs-10 text-muted fw-semibold mb-1">Complaint Description</label>
                                <textarea class="form-control fs-11" rows="3"
                                          name="ComplaintDescription" id="inpComplaintDescription"></textarea>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-6">
                            <div class="form-group mb-3">
                                <label class="fs-10 text-muted fw-semibold mb-1">Additional Description</label>
                                <textarea class="form-control fs-11" rows="2"
                                          name="ComplaintAdditionalDescription" id="inpComplaintAdditionalDescription"></textarea>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="form-group mb-3">
                                <label class="fs-10 text-muted fw-semibold mb-1">Remarks</label>
                                <textarea class="form-control fs-11" rows="2"
                                          name="ComplaintRemarks" id="inpComplaintRemarks"></textarea>
                            </div>
                        </div>
                    </div>

                    <div class="row align-items-end">
                        <div class="col-4">
                            <div class="form-group mb-3">
                                <label class="fs-10 text-muted fw-semibold mb-1">Status</label>
                                <select class="form-select fs-11" name="Status" id="inpStatus">
                                    <option value="" selected disabled>Select Status</option>
                                    <option value="Open">Open</option>
                                    <option value="On-going">On-going</option>
                                    <option value="Settled">Settled</option>
                                    <option value="Transferred">Transferred</option>
                                    <option value="Dismissed">Dismissed</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-4" id="divSettledDate" style="display:none;">
                            <div class="form-group mb-3">
                                <label class="fs-10 text-muted fw-semibold mb-1">Settled Date</label>
                                <input type="date" class="form-control fs-11"
                                       name="SettledDate" id="inpSettledDate">
                            </div>
                        </div>
                        <div class="col-auto">
                            <div class="form-group mb-3">
                                <label class="custom-checkbox fs-10 text-muted fw-semibold">
                                    <input type="checkbox" name="IncidentForTransfer" id="inpIncidentForTransfer">
                                    <span class="checkmark"></span> For Transfer
                                </label>
                            </div>
                        </div>
                    </div>

                    <h6 class="fs-16 fw-bold mt-4">Case Payment Information</h6>

                    <div class="row">
                        <div class="col-3">
                            <div class="form-group mb-3">
                                <label class="fs-10 text-muted fw-semibold mb-1">Time Filed</label>
                                <input type="time" class="form-control fs-11"
                                       name="TimeFiled" id="inpTimeFiled">
                            </div>
                        </div>
                        <div class="col-3">
                            <div class="form-group mb-3">
                                <label class="fs-10 text-muted fw-semibold mb-1">OR No.</label>
                                <input type="text" class="form-control fs-11"
                                       name="ORNo" id="inpORNo" placeholder="e.g. 31480S1">
                            </div>
                        </div>
                        <div class="col-3">
                            <div class="form-group mb-3">
                                <label class="fs-10 text-muted fw-semibold mb-1">Date Issued</label>
                                <input type="date" class="form-control fs-11"
                                       name="DateIssued" id="inpDateIssued">
                            </div>
                        </div>
                        <div class="col-3">
                            <div class="form-group mb-3">
                                <label class="fs-10 text-muted fw-semibold mb-1">Amount</label>
                                <input type="number" step="0.01" min="0" class="form-control fs-11"
                                       name="Amount" id="inpAmount" placeholder="0.00">
                            </div>
                        </div>
                    </div>

                    <hr class="my-3" style="border-color:#e0e0e0;">

                    @* Complainant / Respondent Tabs *@
                    <ul class="nav nav-tabs border-bottom-dash" id="tabParties" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active fw-semibold fs-14 px-4"
                                    id="tab-complainant" data-bs-toggle="tab"
                                    data-bs-target="#pane-complainant" type="button" role="tab"
                                    aria-controls="pane-complainant" aria-selected="true">
                                <i class="bi bi-person-fill me-1"></i> Complainant
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link fw-semibold fs-14 px-4"
                                    id="tab-respondent" data-bs-toggle="tab"
                                    data-bs-target="#pane-respondent" type="button" role="tab"
                                    aria-controls="pane-respondent" aria-selected="false">
                                <i class="bi bi-person-fill-exclamation me-1"></i> Respondent
                            </button>
                        </li>
                    </ul>

                    <div class="tab-content border border-top-0 rounded-bottom px-3 py-3 mb-3">

                        @* Complainant Pane *@
                        <div class="tab-pane fade show active" id="pane-complainant"
                             role="tabpanel" aria-labelledby="tab-complainant">
                            <div class="d-flex justify-content-between align-items-center mt-2 mb-3">
                                <span class="fs-10 text-muted fst-italic">
                                    <i class="bi bi-info-circle me-1"></i>
                                    May be a registered resident or manually entered. Multiple allowed.
                                </span>
                                <div class="d-flex gap-1">
                                    <button type="button" class="btn btn-main-outline btn-sm fw-semibold"
                                            id="btnSearchComplainantResident"
                                            data-bs-toggle="modal" data-bs-target="#mdlFindComplainant">
                                        <i class="bi bi-person-search me-1"></i> Search Resident
                                    </button>
                                    <button type="button" class="btn btn-main-outline btn-sm fw-semibold"
                                            id="btnEncodeComplainant"
                                            data-bs-toggle="modal" data-bs-target="#mdlAddComplainant">
                                        <i class="bi bi-pencil-square me-1"></i> Encode Complainant
                                    </button>
                                </div>
                            </div>
                            <div id="divComplainantCards" class="d-flex flex-column gap-2">
                                <div class="text-center py-3">
                                    <i class="bi bi-person-dash fs-24 text-muted"></i>
                                    <p class="text-muted fs-11 mt-1 mb-0">No complainants added yet.</p>
                                </div>
                            </div>
