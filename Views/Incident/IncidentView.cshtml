                                    id="btnAddSettlement" data-bs-toggle="modal" data-bs-target="#mdlSettlement">
                                <i class="bi bi-plus-lg me-1"></i> Add Schedule
                            </button>
                        </div>
                        <div id="divSettlementCards" class="d-flex flex-column gap-2">
                            <div class="text-center py-4">
                                <i class="bi bi-calendar-x fs-24 text-muted"></i>
                                <p class="text-muted fs-11 mt-1 mb-0">No settlement schedules yet.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm rounded-3 mt-5">
                    <div class="card-body px-3 py-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h6 class="fw-bold mb-0" style="color:#1a6c8a;">
                                <i class="bi bi-paperclip me-1"></i> Attachments
