@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewBag.Title = "Reports";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="form-container mx-5">
    <div class="mb-5">
        <div class="row mx-3 border-bottom-dash border-1 py-2">
            <div class="col-auto pe-0">
                <img src="/img/png/reports.png" alt="ATLAS Logo" class="icon-png">
            </div>
            <div class="col ps-0 d-flex align-items-center">
                <div>
                    <h3 class="fw-bold mb-0">Report Management</h3>
                    <p class="text-muted fs-12 w-75">allows users to generate, view, and manage reports within the application. It transforms stored data into organized, readable outputs that can be filtered, printed, or downloaded, helping users track information and make informed decisions.</p>
                </div>
            </div>
        </div>
    </div>
</div>
<input type="hidden" name="ResidentId" id="hddnResidentId"/>
<div class="row mx-5">
    <div class="col-2">
        <div class="form-group">
            <span class="d-flex justify-content-between fs-10 form-label text-muted fw-semibold mb-0">Type of Report </span>
            <select class="form-select fs-11 text-muted " name="ReportType" id="slctReportType">
                <option value="" class="text-muted" selected disabled>Select Type of Report</option>
                <option value="Clearance">Barangay Clearance</option>
                <option value="Indigency">Certification of Indigency</option>
            </select>
        </div>
    </div>
    <div class="col-4 ps-2">
        <div class="form-group">
            <span class="d-flex justify-content-between fs-10 form-label text-muted fw-semibold mb-0">Resident Name </span>
            <input type="text" class="form-control fs-11 ps-3 text-muted" id="inpResident" name="Resident" placeholder="" readonly>
        </div>
    </div>
    <div class="col ps-2 d-flex align-items-end">
        <div class="form-group">
            <button type="button" class="btn btn-main-outline btn-sm fw-semibold pt-2" id="btnSearchResident" data-bs-toggle="modal" data-bs-target="#mdlResident"><i class="icon-search me-1"></i> Search Resident </button>
        </div>
    </div>
</div>


<div  id="divBarangayClearance" class="d-none">
    <div class="row mt-5 mx-5">
        <div class="col">
            <h6 class="fs-16 fw-bold">Barangay Clearance Information </h6>
        </div>
    </div>

    <div class="row pt-2 mx-5">
        <div class="col-3 ps-2">
            <div class="form-group">
                <span class="d-flex justify-content-between fs-10 form-label text-muted fw-semibold mb-0">CTC No </span>
                <input type="text" class="form-control fs-11 ps-3 text-muted " name="CTCNo" id="" placeholder="">
            </div>
        </div>
        <div class="col ps-2">
            <div class="form-group">
                <span class="d-flex justify-content-between fs-10 form-label text-muted fw-semibold mb-0">Purpose </span>
                <input type="text" class="form-control fs-11 ps-3 text-muted " name="Purpose" placeholder="">
            </div>
        </div>
        <div class="col ps-2 d-flex align-items-end">
            <div class="form-group">
                <button type="button" class="btn btn-main-outline btn-sm fw-semibold pt-2" id="btnPreviewClearance"><i class="icon-print me-1"></i> Preview Barangay Clearance Report </button>
            </div>
        </div>
    </div>
</div>
<div id="divIndigentCertificate" class="d-none">
    <div class="row mt-5 mx-5">
        <div class="col">
            <h6 class="fs-16 fw-bold"> Certificate of Indigency Information </h6>
        </div>
    </div>

    <div class="row pt-2 mx-5">
        <div class="col ps-2">
            <div class="form-group">
                <span class="d-flex justify-content-between fs-10 form-label text-muted fw-semibold mb-0">Purpose </span>
                <input type="text" class="form-control fs-11 ps-3 text-muted " name="Purpose" placeholder="">
            </div>
        </div>
        <div class="col ps-2 d-flex align-items-end">
            <div class="form-group">
                <button type="button" class="btn btn-main-outline btn-sm fw-semibold pt-2" id="btnPreviewIndigency"><i class="icon-print me-1"></i> Preview Certificate of Indigency Report </button>
            </div>
        </div>
    </div>
</div>



<div class="modal fade" id="mdlResident" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content shadow-lg">
            <div class="modal-header flex-column align-items-start border-bottom-0">

                <div class="row ms-1 border-bottom-dash w-100 border-1 py-2">
                    <div class="col-auto pe-0">
                        <img src="/img/_icons/illustrations/search_resident.svg" alt="ATLAS Logo" class="icon-xxxl">
                    </div>
                    <div class="col ps-0 d-flex align-items-center">
                        <div>
                            <h3 class="fw-bold mb-0">Search Resident</h3>
                            <p class="text-muted fs-12 w-100">Filter residents by name to quickly find and access their details.</p>
                        </div>
                    </div>
                </div>

                <!-- Search -->
                <div class="w-75 mt-4">
                    <div class="search-box">
                        <i class="icon-search"></i>
                        <input type="text" class="form-control fs-11 border-elm" id="searchResidentInput" placeholder="Search by name...">
                    </div>
                </div>
            </div>

            <div class="modal-body p-2">
                <div class="card mx-2 rounded-2">
                    <div class="card-body shadow-sm border-1 p-0">
                        <table id="tblResident" class="display dataTable table-striped table-hover w-100"> </table>
                    </div>
                </div>

            </div>

            <div class="d-flex justify-content-between p-3">
                <button type="button" class="btn btn-main-outline btn-sm px-3 fs-11 mb-0" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>



<div class="modal fade" id="mdlPreviewReport" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content shadow-lg">
            <div class="modal-header flex-column align-items-start border-bottom-0 pb-0">
                <div class="row ms-1 border-bottom-dash w-100 border-1 py-2">
                    <div class="col-auto pe-0">
                        <img src="/img/_icons/illustrations/house.svg" alt="ATLAS Logo" class="icon-xxxl">
                    </div>
                    <div class="col ps-0 d-flex align-items-center">
                        <div>
                            <h3 class="fw-bold mb-0">Preview report</h3>
                            <p class="text-muted fs-12 mb-0">A quick view of the generated report. It allows users to review the layout, content, and accuracy of the data, ensuring everything is correct before printing or downloading.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-body p-0" style="height: 80vh; overflow: hidden;">
                <div class="card h-100 border-0 rounded-0 px-3">
                    <div class="card-body p-0 h-100">
                        <iframe id="pdfFrame" src="" frameborder="0" style="width: 100%; height: 100%; display: block;"></iframe>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-end p-3">
                <button type="button" class="btn btn-main-outline btn-sm px-3 fs-11 mb-0" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<script src="~/js/_defined/_reports.js"></script>