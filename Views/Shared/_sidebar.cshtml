<div class="header-box px-0 pt-4 pb-1 d-block justify-content-center text-center">
    <div class="text-center login-logo">
        <img class="d-inline-flex me-1" style=" width: 150px; height: 150px; object-fit: cover;" src="~/img/png/report_logo_nobg.png" />
    </div>

    <h3 class="fs-16 fw-bold mb-0 mt-2 text-opacity-75">@ViewBag.BarangayAddress</h3>
    <p class="fs-12 fw-medium text-muted text-opacity-25">@ViewBag.CityMunAddress</p>

</div>

<hr class="text-muted mx-4" />

<ul class="list-unstyled px-4 navfont">
    <li class="dashboard-nav active">
        <a href="/Dashboard/Dashboard" class="text-decoration-none px-3 py-2 d-block">
            <img src="~/img/_icons/sidenav/dashboard.svg" alt="ATLAS Logo" class="pe-2"> Dashboard
        </a>
    </li>
    <li class="resident-nav">
        <a href="/Resident/ResidentInformation" class="text-decoration-none px-3 py-2 d-block">
            <img src="~/img/_icons/sidenav/residents.svg" alt="ATLAS Logo" class="pe-2"> Residents
        </a>
    </li>
    <li class="officials-nav">
        <a href="/BarangayOfficials/OfficialsInformation" class="text-decoration-none d-flex justify-content-between px-3 py-2 d-block">
            <span> <img src="~/img/_icons/sidenav/certificate.svg" alt="ATLAS Logo" class="pe-2"> Officials</span>
        </a>
    </li>
    <li class="archive-nav">
        <a href="/ArchiveDocument/Archive" class="text-decoration-none d-flex justify-content-between px-3 py-2 d-block">
            <span>
                <img src="~/img/_icons/sidenav/clearance.svg" alt="ATLAS Logo" class="pe-2"> Archive
            </span>
        </a>
    </li>
    <li class="ctc-nav">
        <a href="/CommunityTax/CTC" class="text-decoration-none px-3 py-2 d-block">
            <img src="~/img/_icons/sidenav/report.svg" alt="ATLAS Logo" class="pe-2"> Community Tax
        </a>
    </li>
    <li class="reports-nav">
        <a href="/Reports/Reports" class="text-decoration-none px-3 py-2 d-block">
            <img src="~/img/_icons/sidenav/report.svg" alt="ATLAS Logo" class="pe-2"> Reports
        </a>
    </li>



    <li class="incident-nav">
        <a href="/Incident/IncidentView" class="text-decoration-none px-3 py-2 d-block">
            <img src="~/img/_icons/sidenav/incident.svg" alt="ATLAS Logo" class="pe-2"> Incident
        </a>
    </li>

    

</ul>
<hr class="text-muted mx-4" />
<ul class="list-unstyled px-4 navfont">
    <li class="filemaintenance-nav"><a href="/FileMaintenace/FileMaintenace" class="text-decoration-none px-3 py-2 d-block"><img src="~/img/_icons/sidenav/maintenance.svg" alt="ATLAS Logo" class="pe-2"> Maintenance</a></li>
    <li class="systemmanager-nav"><a href="/SystemManager/SystemManager" class="text-decoration-none px-3 py-2 d-block"><img src="~/img/_icons/sidenav/system.svg" alt="ATLAS Logo" class="pe-2"> System Management</a></li>
</ul>



